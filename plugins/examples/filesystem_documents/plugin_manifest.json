{
  "schema_version": 1,
  "plugin_id": "filesystem_documents",
  "version": "0.1.0",
  "runtime": "external",
  "entrypoint": "run.sh",
  "capabilities": {
    "snapshot": true,
    "incremental": true,
    "webhook": false
  },
  "requirements": {
    "tools": [
      {
        "check": "pandoc",
        "brew": "pandoc"
      },
      {
        "check": "docling",
        "pipx": "docling",
        "install_hint": "pipx install docling"
      },
      {
        "check": "soffice",
        "brew_cask": "libreoffice",
        "install_hint": "brew install --cask libreoffice"
      },
      {
        "check": "pdftotext",
        "brew": "poppler",
        "optional": true,
        "install_hint": "brew install poppler (improves some PDF tooling)"
      }
    ]
  }
}
