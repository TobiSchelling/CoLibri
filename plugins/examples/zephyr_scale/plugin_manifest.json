{
  "schema_version": 1,
  "plugin_id": "zephyr_scale",
  "version": "0.1.0",
  "runtime": "python",
  "entrypoint": "plugin.py",
  "capabilities": {
    "snapshot": true,
    "incremental": true,
    "webhook": false
  },
  "auth": [
    "token"
  ],
  "config_schema": {
    "type": "object",
    "required": [
      "project_key"
    ],
    "properties": {
      "project_key": {
        "type": "string",
        "description": "Zephyr Scale Jira project key (example: CTSLAB)."
      },
      "folder": {
        "type": "string",
        "description": "Optional folder path filter (example: \"/Regression/Login\")."
      },
      "connector_instance": {
        "type": "string",
        "description": "Stable instance label (defaults to \"zephyrscale:<project_key>\")."
      },
      "classification": {
        "type": "string",
        "enum": [
          "restricted",
          "confidential",
          "internal",
          "public"
        ],
        "default": "internal"
      },
      "doc_type": {
        "type": "string",
        "default": "test_case"
      },
      "api_base_url": {
        "type": "string",
        "default": "https://api.zephyrscale.smartbear.com/v2/"
      },
      "token_env": {
        "type": "string",
        "default": "ZEPHYR_API_TOKEN",
        "description": "Environment variable name used to pass the Zephyr API token to the exporter."
      },
      "token": {
        "type": "string",
        "description": "Optional token value (not recommended; prefer env var)."
      },
      "zephyr_export_cmd": {
        "type": "string",
        "default": "zephyr-export",
        "description": "Path or command name for the zephyr-export CLI."
      },
      "include_steps": {
        "type": "boolean",
        "default": true
      },
      "include_custom_fields": {
        "type": "boolean",
        "default": true
      },
      "mode": {
        "type": "string",
        "enum": [
          "snapshot",
          "incremental"
        ],
        "default": "incremental"
      },
      "emit_tombstones": {
        "type": "boolean",
        "default": true,
        "description": "Emit deleted=true envelopes for test cases removed in Zephyr (only for full-project exports)."
      }
    },
    "additionalProperties": false
  },
  "cursor_strategy": "timestamp",
  "retry_policy": {
    "max_attempts": 1,
    "backoff_ms": 0
  },
  "requirements": {
    "tools": [
      {
        "check_from_config": "zephyr_export_cmd",
        "default": "zephyr-export",
        "install_hint": "Install zephyr-export and/or set config.zephyr_export_cmd to its path"
      }
    ],
    "env": [
      {
        "name_from_config": "token_env",
        "default": "ZEPHYR_API_TOKEN",
        "required": true,
        "hint": "export ZEPHYR_API_TOKEN=... (or set config.token_env / config.token)"
      }
    ]
  }
}
