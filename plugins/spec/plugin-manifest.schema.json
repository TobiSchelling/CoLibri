{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://colibri.dev/schemas/plugin-manifest.v1.json",
  "title": "CoLibri Plugin Manifest v1",
  "type": "object",
  "required": [
    "schema_version",
    "plugin_id",
    "version",
    "runtime",
    "entrypoint",
    "capabilities"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "plugin_id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "string",
      "enum": [
        "python",
        "rust",
        "wasm",
        "external"
      ]
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "object",
      "required": [
        "snapshot",
        "incremental",
        "webhook"
      ],
      "additionalProperties": false,
      "properties": {
        "snapshot": {
          "type": "boolean"
        },
        "incremental": {
          "type": "boolean"
        },
        "webhook": {
          "type": "boolean"
        }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "check": {
                "type": "string",
                "description": "Tool name to resolve on PATH (via `which`) or absolute path."
              },
              "check_from_config": {
                "type": "string",
                "description": "Config key whose value provides the tool/path to check (example: zephyr_export_cmd)."
              },
              "default": {
                "type": "string",
                "description": "Default tool name when check_from_config is missing."
              },
              "brew": {
                "type": "string",
                "description": "Homebrew formula name to install."
              },
              "brew_cask": {
                "type": "string",
                "description": "Homebrew cask name to install."
              },
              "pipx": {
                "type": "string",
                "description": "pipx package name to install."
              },
              "install_hint": {
                "type": "string"
              },
              "optional": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "env": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "required"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Environment variable to check."
              },
              "name_from_config": {
                "type": "string",
                "description": "Config key whose value provides the env var name (example: token_env)."
              },
              "default": {
                "type": "string",
                "description": "Default env var name when name_from_config is missing."
              },
              "required": {
                "type": "boolean"
              },
              "hint": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "configure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entrypoint": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["entrypoint"]
    }
  }
}
